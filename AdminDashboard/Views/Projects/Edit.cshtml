@model Core.Models.Project
@using Core.Enums

@{
    ViewData["Title"] = "Edit Project";
    
    // Fallbacks for languages
    var enTrans = Model.Translations?.FirstOrDefault(t => t.Language == Language.en);
    var arTrans = Model.Translations?.FirstOrDefault(t => t.Language == Language.ar);
}

<h1>Editing @(enTrans?.Title ?? "Project")</h1>

<hr />
<form asp-action="Edit" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Id" />
    
    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="Slug" class="form-label"></label>
            <input asp-for="Slug" class="form-control" />
            <span asp-validation-for="Slug" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="PublishedAt" class="form-label"></label>
            <input asp-for="PublishedAt" class="form-control" type="date" value="@Model.PublishedAt.ToString("yyyy-MM-dd")" />
            <span asp-validation-for="PublishedAt" class="text-danger"></span>
        </div>
    </div>
    
    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="LiveUrl" class="form-label"></label>
            <input asp-for="LiveUrl" class="form-control" />
            <span asp-validation-for="LiveUrl" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="DemoUrl" class="form-label"></label>
            <input asp-for="DemoUrl" class="form-control" />
            <span asp-validation-for="DemoUrl" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Technologies" class="form-label"></label>
        <select asp-for="Technologies" class="form-control" asp-items="ViewBag.Technologies" multiple></select>
        <span asp-validation-for="Technologies" class="text-danger"></span>
    </div>

    <!-- Translations Tabs -->
    <h4 class="mt-4">Translations</h4>
    <ul class="nav nav-tabs" id="translationsTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="en-tab" data-bs-toggle="tab" data-bs-target="#en" type="button" role="tab" aria-controls="en" aria-selected="true">English</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="ar-tab" data-bs-toggle="tab" data-bs-target="#ar" type="button" role="tab" aria-controls="ar" aria-selected="false">Arabic</button>
        </li>
    </ul>

    <div class="tab-content border border-top-0 p-3 mb-4" id="translationsTabContent">
        <!-- English Translation -->
        <div class="tab-pane fade show active" id="en" role="tabpanel" aria-labelledby="en-tab">
            <input type="hidden" name="Translations[0].Language" value="@((int)Language.en)" />
            <div class="mb-3">
                <label class="form-label">Title (English) <span class="text-danger">*</span></label>
                <input name="Translations[0].Title" class="form-control" value="@(enTrans?.Title)" />
            </div>
            <div class="mb-3">
                <label class="form-label">Description (English) <span class="text-danger">*</span></label>
                <textarea name="Translations[0].Description" class="form-control" rows="3">@(enTrans?.Description)</textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Client (English)</label>
                <input name="Translations[0].Client" class="form-control" value="@(enTrans?.Client)" />
            </div>
             <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label">Problem (English) <span class="text-danger">*</span></label>
                    <textarea name="Translations[0].Problem" class="form-control" rows="3">@(enTrans?.Problem)</textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Solution (English) <span class="text-danger">*</span></label>
                    <textarea name="Translations[0].Solution" class="form-control" rows="3">@(enTrans?.Solution)</textarea>
                </div>
            </div>
        </div>

        <!-- Arabic Translation -->
        <div class="tab-pane fade" id="ar" role="tabpanel" aria-labelledby="ar-tab" dir="rtl">
            <input type="hidden" name="Translations[1].Language" value="@((int)Language.ar)" />
            <div class="mb-3">
                <label class="form-label">Title (Arabic) <span class="text-danger">*</span></label>
                <input name="Translations[1].Title" class="form-control" value="@(arTrans?.Title)" />
            </div>
            <div class="mb-3">
                <label class="form-label">Description (Arabic) <span class="text-danger">*</span></label>
                <textarea name="Translations[1].Description" class="form-control" rows="3">@(arTrans?.Description)</textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Client (Arabic)</label>
                <input name="Translations[1].Client" class="form-control" value="@(arTrans?.Client)" />
            </div>
             <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label">Problem (Arabic) <span class="text-danger">*</span></label>
                    <textarea name="Translations[1].Problem" class="form-control" rows="3">@(arTrans?.Problem)</textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Solution (Arabic) <span class="text-danger">*</span></label>
                    <textarea name="Translations[1].Solution" class="form-control" rows="3">@(arTrans?.Solution)</textarea>
                </div>
            </div>
        </div>
    </div>
    
    <div>
        <input type="submit" value="Save" class="btn btn-primary" />
    </div>
</form>

<div class="py-3">
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
