@model IEnumerable<Core.Models.Project>

@{
    ViewData["Title"] = "All Projects";
}

<h1>All Projects</h1>
<a asp-action="Create" class="btn btn-primary">Create New</a>

<table class="content-table">
    <thead>
        <tr>
            <th>
                Title (EN)
            </th>
            <th>
                Description (EN)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Technologies)
            </th>
            <th>
                Client
            </th>
            <th>
                <!-- Empty for IsFeature column -->
            </th>
            <th>
                Languages
            </th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr class="clickable-row" data-href="@Url.Action("Edit", "Projects", new { id = item.Id })" style="cursor: pointer;">
            <td>
                @(item.Translations?.FirstOrDefault()?.Title ?? "-")
            </td>
            <td title="@(item.Translations?.FirstOrDefault()?.Description)">
                @((item.Translations?.FirstOrDefault()?.Description?.Length ?? 0) > 25
                                ? item.Translations.FirstOrDefault().Description.Substring(0, 25) + "…"
                                : item.Translations?.FirstOrDefault()?.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Technologies)
            </td>
            <td>
                @(item.Translations?.FirstOrDefault()?.Client ?? "-")
            </td>
            <td>
                 <!-- removed IsFeatured condition -->
            </td>
            <td>
                 @(item.Translations?.Count ?? 0) Langs
            </td>
        </tr>
}
    </tbody>
</table>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('tr.clickable-row').forEach(function (row) {
            row.addEventListener('click', function (e) {
                if (e.target.closest('a, button, input, label')) return;
                const href = row.getAttribute('data-href');
                if (href) window.location = href;
            });
        });
    });
</script>
